# Example .env for apps/engine (frontend)
# Copy this file to `apps/engine/.env` and fill real values before running or deploy

# Public API URL used by the browser (must start with NEXT_PUBLIC_ to be exposed)
NEXT_PUBLIC_API_URL=https://your-api.example.com/api/v1
NEXT_PUBLIC_WS_URL=wss://your-api.example.com
NEXT_PUBLIC_APP_NAME=Engine

# Internal API URL (server-side usage)
API_INTERNAL_URL=https://your-api.example.com

# Port for Next (only used for local dev or when running directly)
PORT=3001

# Any other NEXT_PUBLIC_* variables used by the frontend
# NEXT_PUBLIC_ANALYTICS_ID=your-analytics-id
# Example .env for apps/engine
# - Jangan masukkan kredensial nyata di file ini
# - Salin ke `.env` atau `.env.local` lalu isi nilai sensitif sebelum menjalankan

# URL API yang dapat diakses dari browser (harus pakai prefix NEXT_PUBLIC_)
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1

# WebSocket (opsional)
NEXT_PUBLIC_WS_URL=ws://localhost:4000

# Nama aplikasi untuk tampilan/branding
NEXT_PUBLIC_APP_NAME=Engine

# Contoh variabel server-only (jangan beri prefix NEXT_PUBLIC_ jika hanya server-side)
API_INTERNAL_URL=http://localhost:4000

# Port dev (Next memakai -p 3001 di scripts, tapi bisa diatur di env jika diperlukan)
PORT=3001

# Contoh placeholder untuk secret (ganti di .env nyata)
API_SECRET_PLACEHOLDER=replace_me
