# --- API & internal services (use service hostnames in compose) ---
DATABASE_URL=postgresql://postgres:postgres_password@postgres:5432/wavo?schema=public
REDIS_URL=redis://redis:6379
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=minio_root
MINIO_SECRET_KEY=minio_password
MINIO_BUCKET=wavo-storage

# App runtime
NODE_ENV=production
PORT=4000

# Security (rotate these; keep private in Dokploy Secrets)
JWT_PRIVATE_KEY=Kp9X7sN4vQyR8tZ2bM6uF1wL0eH3cG5n
ENCRYPTION_KEY=6f2b9c3a8d1e4f5a6b7c8d9e0f1a2b3c
BCRYPT_ROUNDS=12

# --- Frontend (engine) — only change the domain below ---
# This must be the public URL the browser will call (set before engine build)
NEXT_PUBLIC_API_URL=https://<FRONTEND_DOMAIN>
NEXT_PUBLIC_WS_URL=wss://<FRONTEND_DOMAIN>
NEXT_PUBLIC_APP_NAME=Wavo
NODE_ENV=production
PORT=3000