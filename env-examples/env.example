# ═══════════════════════════════════════════════════════════════
# WAVO — Dokploy Environment Variables
# Paste this into Dokploy → Compose → Environment / Secrets
# ═══════════════════════════════════════════════════════════════

# ── DATABASE (internal Docker network) ────────────────────────
DATABASE_URL=postgresql://postgres:postgres_password@postgres:5432/wavo?schema=public

# ── REDIS ─────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── OBJECT STORAGE (MinIO — internal) ────────────────────────
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=minio_root
MINIO_SECRET_KEY=minio_password
MINIO_BUCKET=wavo-storage
MINIO_USE_SSL=false

# ── SECURITY (ganti dengan value production yang aman!) ──────
JWT_PRIVATE_KEY=Kp9X7sN4vQyR8tZ2bM6uF1wL0eH3cG5n
JWT_PUBLIC_KEY=Kp9X7sN4vQyR8tZ2bM6uF1wL0eH3cG5n
ENCRYPTION_KEY=6f2b9c3a8d1e4f5a6b7c8d9e0f1a2b3c
BCRYPT_ROUNDS=12

# ── FRONTEND BUILD ARGS (Next.js — baked at build time) ──────
# PENTING: harus include /api/v1 karena frontend append endpoint
# contoh: API_BASE_URL + "/auth/register" = full URL
NEXT_PUBLIC_API_URL=https://api-usewavo.lumicloud.my.id/api/v1
NEXT_PUBLIC_WS_URL=wss://api-usewavo.lumicloud.my.id
NEXT_PUBLIC_APP_NAME=Wavo
